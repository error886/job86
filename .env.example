# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# VITE_KAKAO_MAP_KEY: Kakao Map Javascript App Key
VITE_KAKAO_MAP_KEY=""

# --- COOLIFY & PRODUCTION DEPLOYMENT CONFIGURATIONS ---

# DATA_PATH: Optional directory where the local database (db.json) will be stored.
# If you want to persist the database on Coolify, set this to a folder (e.g. /app/data)
# and mount a persistent volume to that folder in Coolify.
DATA_PATH=""

# FIREBASE CONFIGURATIONS:
# Use these if you want to deploy onto Coolify while connecting to your Firebase Firestore database.
# If these are left blank, the app automatically falls back to local JSON database storage (db.json).
FIREBASE_PROJECT_ID=""
FIREBASE_DATABASE_ID=""

# FIREBASE_SERVICE_ACCOUNT:
# The complete Firebase Service Account JSON string (e.g. {"type": "service_account", ...})
# so the application can authenticate with Firestore from outside Google Cloud.
FIREBASE_SERVICE_ACCOUNT=""

